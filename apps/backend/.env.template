STORE_CORS=http://localhost:8000,http://localhost:8001,https://docs.medusajs.com
ADMIN_CORS=http://localhost:5173,http://localhost:9000,https://docs.medusajs.com
AUTH_CORS=http://localhost:5173,http://localhost:9000,http://localhost:8000,http://localhost:8001,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
DATABASE_URL=postgres://postgres:hema123@localhost:5432/ecommerce
DB_NAME=ecommerce

# Public URL where the Medusa backend is reachable by browsers and Admin.
MEDUSA_BACKEND_URL=http://localhost:9000

# Local upload provider. Local storage is suitable for development; use S3-compatible
# storage in production so files survive container rebuilds and horizontal scaling.
FILE_PROVIDER=local
LOCAL_FILE_UPLOAD_DIR=
LOCAL_FILE_PRIVATE_UPLOAD_DIR=

# Public URL serving seeded storefront demo images, for example the storefront URL
# in development or a CDN/static asset host in production.
FRESHMART_IMAGE_BASE_URL=http://localhost:8000

# S3-compatible upload provider. Set FILE_PROVIDER=s3 and fill these in production.
S3_FILE_URL=
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_PREFIX=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
S3_AUTHENTICATION_METHOD=access-key
S3_CACHE_CONTROL=public, max-age=31536000

# Razorpay payment gateway (required for Online Payment)
# Get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
# Set to "false" to authorize without auto-capturing
RAZORPAY_AUTO_CAPTURE=true
